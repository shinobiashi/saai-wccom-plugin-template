{
	"compilerOptions": {
		"target": "ES2020",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"outDir": "./dist",
		"rootDir": ".",
		"types": [ "@playwright/test", "node" ]
	},
	"include": [ "**/*.ts" ],
	"exclude": [ "node_modules", "dist", "test-results" ]
}
