includes:
    - phpstan-baseline.neon

parameters:
    level: 5

    paths:
        - plugin-name.php
        - includes/

    excludePaths:
        - vendor/
        - node_modules/
        - build/
        - tests/

    bootstrapFiles:
        - vendor/autoload.php

    # WooCommerce stubs are not bundled — suppress known WC symbols.
    ignoreErrors:
        - '#Function wc_\w+ not found#'
        - '#Class WC_\w+ not found#'
        - '#Class Automattic\\\\WooCommerce\\\\#'
